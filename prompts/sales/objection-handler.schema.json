{
  "type": "object",
  "properties": {
    "classification": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "string",
          "enum": ["price", "timing", "authority", "competitor", "fit", "trust", "stall"]
        },
        "secondary": {
          "type": "string",
          "enum": ["price", "timing", "authority", "competitor", "fit", "trust", "stall", "none"],
          "description": "Use 'none' if no clear secondary."
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["primary", "secondary", "confidence"]
    },
    "responses": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "approach": { "type": "string", "description": "1-line description of the strategy." },
          "scriptedResponse": { "type": "string", "description": "2-4 sentences a rep could say verbatim." }
        },
        "required": ["approach", "scriptedResponse"]
      }
    },
    "assessment": {
      "type": "string",
      "description": "Honest read of the deal state. Includes whether to keep pushing, slow-play, or disqualify."
    },
    "shouldDisqualify": { "type": "boolean" }
  },
  "required": ["classification", "responses", "assessment", "shouldDisqualify"]
}
