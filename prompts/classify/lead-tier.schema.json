{
  "type": "object",
  "properties": {
    "tier": { "type": "string", "enum": ["A", "B", "C"] },
    "criteriaMet": {
      "type": "object",
      "properties": {
        "decisionMakerTitle": { "type": "boolean" },
        "companyFit": { "type": "boolean" },
        "buyingSignal": { "type": "boolean" },
        "reachable": { "type": "boolean" }
      },
      "required": ["decisionMakerTitle", "companyFit", "buyingSignal", "reachable"]
    },
    "reasoning": {
      "type": "object",
      "properties": {
        "positiveEvidence": { "type": "array", "items": { "type": "string" } },
        "counterEvidence": { "type": "array", "items": { "type": "string" }, "description": "Disqualifiers or weakening factors. Use [\"none considered\"] only when truly none apply." }
      },
      "required": ["positiveEvidence", "counterEvidence"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "nextStep": { "type": "string", "enum": ["outreach-now", "monitor", "skip"] }
  },
  "required": ["tier", "criteriaMet", "reasoning", "confidence", "nextStep"]
}
